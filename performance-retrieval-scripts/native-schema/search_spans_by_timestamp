SELECT
    count() AS runs,
    avg(query_duration_ms) AS avg_duration_ms,
    avg(read_rows) AS avg_read_rows,
    formatReadableSize(avg(read_bytes)) AS avg_read_bytes,
    avg(result_rows) AS avg_result_rows,
    formatReadableSize(avg(result_bytes)) AS avg_result_bytes,
    formatReadableSize(avg(memory_usage)) AS avg_memory_usage
FROM system.query_log
WHERE query LIKE '%SELECT DISTINCT%s.trace_id%FROM spans s%WHERE%s.start_time >%'
    AND query NOT LIKE '%s.service_name =%'
    AND query NOT LIKE '%s.name =%'
    AND query NOT LIKE '%s.duration%'
    AND query NOT LIKE '%str_attributes%'
    AND query NOT LIKE '%system.query_log%'
    AND query_duration_ms != 0
